<?xml version="1.0" encoding="UTF-8"?>
<constraint-mappings 
    xmlns="https://jakarta.ee/xml/ns/validation/mapping"
    version="3.0">

    <bean class="com.dto.CategorieDTO" ignore-annotations="false">
        
        <field name="catId">
            <constraint annotation="jakarta.validation.constraints.Min">
                <message>{shop.category.invalid}</message>
                <groups>
                    <value>com.validation.group.BasicChecks</value>
                </groups>
                <element name="value">1</element>
            </constraint>
        </field>

        <field name="id">
            <constraint annotation="jakarta.validation.constraints.Min">
                <message>{shop.item.invalid}</message>
                <groups>
                    <value>com.validation.group.BasicChecks</value>
                </groups>
                <element name="value">1</element>
            </constraint>
        </field>
        
    </bean>
</constraint-mappings>